---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Countdown from '../../components/Countdown.astro';
import ParallaxSection from '../../components/ParallaxSection.astro';
import FAQ from '../../components/FAQ.astro';
import Footer from '../../components/Footer.astro';
import { languages } from '../../i18n/ui';

const { lang } = Astro.params;

if (!lang || !Object.keys(languages).includes(lang)) {
    return Astro.redirect('/es/');
}
---

<Layout title="Un Sueño Moderno - Marina & Oswald">
	<Header />
	<main class="flex flex-col min-h-screen w-full pt-16">
        <Hero />
        <Countdown />
        <ParallaxSection />
        <FAQ />
        <Footer />
	</main>
</Layout>
