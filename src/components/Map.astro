---
// src/components/Map.astro
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  url: string;
  address?: string;
}

const { url, address = t("map.address_default") } = Astro.props;

// URL para abrir directamente en la App de Google Maps
const googleMapsAppUrl =
  "https://www.google.com/maps/dir//Finca+Condado+de+Cubillana,+Camino+de+la+iva+sin+numero,+45920+La+Torre+de+Esteban+Hambrán,+Toledo/";
---

<div class="w-full max-w-4xl mx-auto">
  <div
    class="relative overflow-hidden rounded-2xl shadow-xl border border-gray-100"
  >
    <iframe
      src={url}
      width="100%"
      height="250"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      aria-label={t("map.aria_label")}
      class="grayscale-[0.2] contrast-[1.1]"></iframe>
  </div>

  <div class="mt-4">
    <div>
      <p class="font-medium text-sm">{address}</p>
      <p class="text-sm text-gray-500">{t("map.location")}</p>
    </div>

    <a
      href={googleMapsAppUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex mt-1 items-center justify-center px-6 py-3 bg-black text-white text-sm font-semibold rounded-full hover:bg-gray-800 transition-colors duration-300"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4 mr-2"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
        ></path>
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
      {t("map.get_directions")}
    </a>
  </div>
</div>
