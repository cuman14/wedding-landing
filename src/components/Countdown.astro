---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Format the date using Intl for server-side initial rendering (optional) or let client handle it?
// Server-side is better for SEO/performance.
const weddingDate = new Date('2026-10-10T16:30:00'); // 4:30 PM
const formattedDate = new Intl.DateTimeFormat(lang, { 
    year: 'numeric', 
    month: 'long', 
    day: 'numeric' 
}).format(weddingDate);
---

<section id="countdown" class="py-16 md:py-24 px-4 md:px-10 lg:px-40 bg-secondary-mint/30 dark:bg-background-dark">
    <div class="max-w-240 mx-auto flex flex-col items-center gap-8 md:gap-12">
        <div class="text-center space-y-4">
            <div class="inline-block px-4 py-1.5 rounded-full bg-primary/10 text-primary text-[10px] md:text-xs font-body font-bold uppercase tracking-wider mb-2 border border-primary/20">
                {lang === 'es' ? 'La Cuenta Atrás' : 'The Countdown'}
            </div>
            <h2 class="text-3xl md:text-5xl font-body text-text-main-light dark:text-text-main-dark tracking-tight font-semibold">
                {t('countdown.title')}
            </h2>
            <p class="text-gray-600 dark:text-gray-400 max-w-lg mx-auto font-body font-light leading-relaxed text-sm md:text-base">
                {t('countdown.text')}
            </p>
        </div>

        <div class="w-full grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8 text-center" id="countdown-timer" data-date={weddingDate.toISOString()} aria-live="polite" aria-atomic="true">
            <div class="flex flex-col items-center gap-2 p-5 md:p-6 bg-white dark:bg-background-dark rounded-xl shadow-sm border border-pearl-grey dark:border-white/5 hover:border-primary/30 transition-colors">
                <span class="text-4xl md:text-5xl font-body font-light text-text-main-light dark:text-text-main-dark tabular-nums" data-type="days">00</span>
                <span class="text-[10px] uppercase tracking-[0.2em] text-primary font-bold font-body">{t('countdown.days')}</span>
            </div>
            <div class="flex flex-col items-center gap-2 p-5 md:p-6 bg-white dark:bg-background-dark rounded-xl shadow-sm border border-pearl-grey dark:border-white/5 hover:border-primary/30 transition-colors">
                <span class="text-4xl md:text-5xl font-body font-light text-text-main-light dark:text-text-main-dark tabular-nums" data-type="hours">00</span>
                <span class="text-[10px] uppercase tracking-[0.2em] text-primary font-bold font-body">{t('countdown.hours')}</span>
            </div>
            <div class="flex flex-col items-center gap-2 p-5 md:p-6 bg-white dark:bg-background-dark rounded-xl shadow-sm border border-pearl-grey dark:border-white/5 hover:border-primary/30 transition-colors">
                <span class="text-4xl md:text-5xl font-body font-light text-text-main-light dark:text-text-main-dark tabular-nums" data-type="minutes">00</span>
                <span class="text-[10px] uppercase tracking-[0.2em] text-primary font-bold font-body">{t('countdown.minutes')}</span>
            </div>
            <div class="flex flex-col items-center gap-2 p-5 md:p-6 bg-white dark:bg-background-dark rounded-xl shadow-sm border border-pearl-grey dark:border-white/5 relative overflow-hidden group">
                <div class="absolute top-0 right-0 w-16 h-16 bg-primary/5 rounded-bl-full -mr-8 -mt-8 transition-transform group-hover:scale-150 duration-500"></div>
                <span class="text-4xl md:text-5xl font-body font-medium text-primary tabular-nums" data-type="seconds">00</span>
                <span class="text-[10px] uppercase tracking-[0.2em] text-primary font-bold font-body">{t('countdown.seconds')}</span>
            </div>
        </div>

        <div class="mt-4 relative inline-block text-left">
            <button 
                id="calendar-menu-btn"
                class="flex items-center gap-3 bg-primary hover:bg-primary-dark text-white px-6 md:px-8 py-3 md:py-4 rounded-lg font-bold shadow-lg shadow-primary/25 transition-all hover:-translate-y-0.5 font-body cursor-pointer focus-visible:ring-4 focus-visible:ring-primary/50 text-sm md:text-base"
                aria-expanded="false"
                aria-haspopup="true"
            >
                <span class="material-symbols-outlined">calendar_month</span>
                <span>{t('countdown.saveDate')}</span>
                <span id="calendar-arrow" class="material-symbols-outlined text-sm transition-transform">keyboard_arrow_down</span>
            </button>

            <!-- Dropdown Menu -->
            <div 
                id="calendar-dropdown"
                class="hidden absolute left-1/2 -translate-x-1/2 md:left-0 md:translate-x-0 z-20 mt-2 w-56 rounded-xl bg-white dark:bg-background-dark shadow-2xl ring-1 ring-black ring-opacity-5 transition-all duration-200"
                role="menu"
                aria-orientation="vertical"
                aria-labelledby="calendar-menu-btn"
            >
                <div class="p-2 space-y-1 text-left">
                    <button 
                        id="google-cal-btn"
                        class="flex items-center w-full px-4 py-3 text-sm text-gray-700 dark:text-gray-200 hover:bg-primary/5 rounded-lg transition-colors font-body text-left cursor-pointer group/item" 
                        role="menuitem"
                    >
                        <svg class="size-5 mr-3" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zM9 14H7v-2h2v2zm4 0h-2v-2h2v2zm4 0h-2v-2h2v2zm-8 4H7v-2h2v2zm4 0h-2v-2h2v2zm4 0h-2v-2h2v2z" fill="#4285F4"/>
                        </svg>
                        Google Calendar
                    </button>
                    <button 
                        id="outlook-cal-btn"
                        class="flex items-center w-full px-4 py-3 text-sm text-gray-700 dark:text-gray-200 hover:bg-primary/5 rounded-lg transition-colors font-body text-left cursor-pointer group/item" 
                        role="menuitem"
                    >
                        <svg class="size-5 mr-3" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M7.5 13.5v-3l-2.25-1.5L3 10.5v3l2.25 1.5 2.25-1.5z" fill="#0078D4"/>
                            <path d="M21 16.5v-9c0-.83-.67-1.5-1.5-1.5h-9c-.83 0-1.5.67-1.5 1.5v9c0 .83.67 1.5 1.5 1.5h9c.83 0 1.5-.67 1.5-1.5z" fill="#0078D4"/>
                            <path d="M12.75 9.75h4.5v1.5h-4.5v-1.5zm0 3h4.5v1.5h-4.5v-1.5zm0 3h2.25v1.5h-2.25v-1.5z" fill="#fff"/>
                        </svg>
                        Outlook
                    </button>
                    <button 
                        id="ics-cal-btn"
                        class="flex items-center w-full px-4 py-3 text-sm text-gray-700 dark:text-gray-200 hover:bg-primary/5 rounded-lg transition-colors font-body text-left cursor-pointer group/item" 
                        role="menuitem"
                    >
                        <svg class="size-5 mr-3" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                            <path d="M17.05 20.28c-.96.95-2.04.83-3 .34-1.14-.58-2.06-.59-3.23.01-1.2.62-1.89.51-2.77-.32-4.04-3.93-3.41-10.37 1.25-10.64 1.2-.07 2.03.62 2.76.65.92.03 1.95-.73 3.33-.63 1.58.12 2.79.73 3.52 1.77-3.14 1.83-2.61 5.91.53 7.18-.61 1.63-1.48 3.25-2.69 4.64zM12.01 8.93c-.07-2.32 1.94-4.4 4.19-4.53.25 2.61-2.12 4.77-4.19 4.53z"/>
                        </svg>
                        Apple
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function updateCountdown() {
        const timer = document.getElementById('countdown-timer');
        if (!timer) return;
        
        const targetDate = new Date(timer.dataset.date!).getTime();
        const now = new Date().getTime();
        const distance = targetDate - now;

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        const els = {
            days: timer.querySelector('[data-type="days"]'),
            hours: timer.querySelector('[data-type="hours"]'),
            minutes: timer.querySelector('[data-type="minutes"]'),
            seconds: timer.querySelector('[data-type="seconds"]')
        };

        if(els.days) els.days.textContent = days.toString();
        if(els.hours) els.hours.textContent = hours.toString();
        if(els.minutes) els.minutes.textContent = minutes.toString();
        if(els.seconds) els.seconds.textContent = seconds.toString();
    }

    const eventDetails = {
        title: 'Boda Oswald y Marina',
        start: '20261010T163000',
        end: '20261011T003000',
        location: 'Finca Condado de Cubillana, Toledo',
        description: '¡Nuestro gran día! No faltéis.',
    };

    // Calendar Menu Logic
    const menuBtn = document.getElementById('calendar-menu-btn');
    const dropdown = document.getElementById('calendar-dropdown');
    const arrow = document.getElementById('calendar-arrow');

    function toggleMenu() {
        if (!dropdown || !menuBtn || !arrow) return;
        const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
        menuBtn.setAttribute('aria-expanded', (!isExpanded).toString());
        dropdown.classList.toggle('hidden');
        arrow.classList.toggle('rotate-180');
    }

    menuBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleMenu();
    });

    // Close menu when clicking outside
    document.addEventListener('click', () => {
        if (dropdown && !dropdown.classList.contains('hidden')) {
            menuBtn?.setAttribute('aria-expanded', 'false');
            dropdown.classList.add('hidden');
            arrow?.classList.remove('rotate-180');
        }
    });

    // 1. Google Calendar
    document.getElementById('google-cal-btn')?.addEventListener('click', () => {
        const googleUrl = new URL('https://calendar.google.com/calendar/render');
        googleUrl.searchParams.append('action', 'TEMPLATE');
        googleUrl.searchParams.append('text', eventDetails.title);
        googleUrl.searchParams.append('dates', `${eventDetails.start}/${eventDetails.end}`);
        googleUrl.searchParams.append('details', eventDetails.description);
        googleUrl.searchParams.append('location', eventDetails.location);
        window.open(googleUrl.toString(), '_blank');
    });

    // 2. Outlook Web
    document.getElementById('outlook-cal-btn')?.addEventListener('click', () => {
        const outlookUrl = new URL('https://outlook.live.com/calendar/0/deeplink/compose');
        outlookUrl.searchParams.append('path', '/calendar/action/compose');
        outlookUrl.searchParams.append('rru', 'addevent');
        outlookUrl.searchParams.append('subject', eventDetails.title);
        outlookUrl.searchParams.append('startdt', '2026-10-10T16:30:00');
        outlookUrl.searchParams.append('enddt', '2026-10-11T00:30:00');
        outlookUrl.searchParams.append('body', eventDetails.description);
        outlookUrl.searchParams.append('location', eventDetails.location);
        window.open(outlookUrl.toString(), '_blank');
    });

    // 3. Apple / App Predeterminada (ICS)
    document.getElementById('ics-cal-btn')?.addEventListener('click', () => {
        // En móviles, window.location.href es más fiable que window.open para descargas/archivos especiales
        window.location.href = '/api/boda.ics';
    });

    setInterval(updateCountdown, 1000);
    updateCountdown();
</script>
