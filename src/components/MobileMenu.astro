---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div
  id="mobile-menu"
  class="fixed inset-0 z-100 bg-background-light dark:bg-background-dark transform translate-x-full transition-transform duration-300 md:hidden flex flex-col justify-center items-center gap-8"
>
  <button
    id="close-menu"
    class="absolute top-6 right-6 p-2 text-primary focus-visible:ring-2 focus-visible:ring-primary rounded-full"
    aria-label="Cerrar menú"
  >
    <span class="material-symbols-outlined text-3xl" aria-hidden="true"
      >close</span
    >
  </button>

  <nav class="flex flex-col items-center gap-6">
    <a
      class="text-2xl font-body font-medium hover:text-primary transition-colors mobile-link"
      href="#hero">{t("nav.home")}</a
    >
    <a
      class="text-2xl font-body font-medium hover:text-primary transition-colors mobile-link"
      href="#video-section">{t("nav.place")}</a
    >
    <a
      class="text-2xl font-body font-medium hover:text-primary transition-colors mobile-link"
      href="#countdown">{t("nav.countdown")}</a
    >
    <a
      class="text-2xl font-body font-medium hover:text-primary transition-colors mobile-link"
      href="#faq">{t("nav.details")}</a
    >
  </nav>

  <a
    href="#confirmar"
    class="mobile-link mt-4 flex items-center justify-center gap-2 font-body font-medium text-xl uppercase tracking-wide px-8 py-4 rounded-full text-[#7e97b8] bg-[#e0e8ef] border-2 border-white/30 shadow-[-4px_-2px_16px_0_#ffffff,4px_2px_16px_0_rgb(95_157_231/48%)] transition-all hover:bg-[#E5EDF5] active:shadow-none"
  >
    <svg
      viewBox="0 0 24 24"
      width="20"
      height="20"
      stroke="currentColor"
      stroke-width="2"
      fill="none"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
    </svg>
    {t("nav.confirm")}
  </a>
</div>

<script>
  const menu = document.getElementById("mobile-menu");
  const closeBtn = document.getElementById("close-menu");
  const links = document.querySelectorAll(".mobile-link");

  function close() {
    menu?.classList.add("translate-x-full");
  }

  closeBtn?.addEventListener("click", close);

  links.forEach((link) => {
    link.addEventListener("click", close);
  });

  // Listen for open event custom
  document.addEventListener("open-mobile-menu", () => {
    menu?.classList.remove("translate-x-full");
  });
</script>
