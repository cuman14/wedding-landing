---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

/**
 * Componente de Progreso Automatizado
 * Calcula el estado basándose en la fecha actual del servidor/cliente.
 */
const now = new Date();

const steps = [
  {
    date: new Date("2026-01-16"),
    label: t("progress.step1_label"),
    icon: "info",
    displayDate: t("progress.step1_date"),
  },
  {
    date: new Date("2026-04-01"),
    label: t("progress.step2_label"),
    icon: "mail",
    displayDate: t("progress.step2_date"),
  },
  {
    date: new Date("2026-08-01"),
    label: t("progress.step3_label"),
    icon: "check_circle",
    displayDate: t("progress.step3_date"),
  },
  {
    date: new Date("2026-09-01"),
    label: t("progress.step4_label"),
    icon: "celebration",
    displayDate: t("progress.step4_date"),
  },
  {
    date: new Date("2026-10-10"),
    label: t("progress.step5_label"),
    icon: "favorite",
    displayDate: t("progress.step5_date"),
  },
];

const activeIndex = steps.findLastIndex((step) => now >= step.date);
const progressWidth =
  activeIndex === -1 ? 0 : (activeIndex / (steps.length - 1)) * 100;
---

<section class="w-full py-16 px-4 bg-transparent overflow-hidden">
  <div class="max-w-4xl mx-auto">
    <h3
      class="text-2xl font-serif text-center mb-16 italic text-gray-800 dark:text-white"
    >
      {t("progress.title")}
    </h3>

    <div class="relative">
      <!-- Línea base - Horizontal (Desktop) -->
      <div
        class="hidden md:block absolute inset-0 top-1/2 -translate-y-1/2 h-1 bg-gray-200 dark:bg-white/10 rounded-full"
      >
      </div>

      <!-- Línea base - Vertical (Móvil) -->
      <div
        class="md:hidden absolute left-5.5 top-0 bottom-0 w-1 bg-gray-200 dark:bg-white/10 rounded-full"
      >
      </div>

      <!-- Progreso - Horizontal (Desktop) -->
      <div
        class="progress-bar-h hidden md:block absolute left-0 top-1/2 -translate-y-1/2 h-1 bg-black dark:bg-white rounded-full"
        style={`--target-width: ${progressWidth}%`}
      >
      </div>

      <!-- Progreso - Vertical (Móvil) -->
      <div
        class="progress-bar-v md:hidden absolute left-5.5 top-0 w-1 bg-black dark:bg-white rounded-full"
        style={`--target-height: ${progressWidth}%`}
      >
      </div>

      <div
        class="relative flex flex-col md:flex-row justify-between items-start md:items-center w-full space-y-12 md:space-y-0"
      >
        {
          steps.map((step, index) => {
            const isCompleted = now >= step.date;
            const isNext = activeIndex + 1 === index;

            return (
              <div class="flex flex-row md:flex-col items-center md:items-center w-full md:flex-1 min-w-0 z-10 group">
                {/* Fecha - Izquierda en móvil, Arriba en Desktop */}
                <span
                  class={`text-xs md:text-xs mb-0 md:mb-3 font-mono uppercase tracking-widest transition-colors duration-500 w-20 md:w-auto text-right md:text-center mr-4 md:mr-0 ${
                    isCompleted
                      ? "text-black dark:text-white font-bold"
                      : "text-gray-400"
                  }`}
                >
                  {step.displayDate}
                </span>

                {/* Círculo con Icono */}
                <div
                  class={`
                relative z-20 size-11 md:size-11 rounded-full flex items-center justify-center border-2 transition-all duration-700 delay-[${
                  index * 100
                }ms]
                ${
                  isCompleted
                    ? "bg-black border-black text-white dark:bg-white dark:border-white dark:text-black shadow-xl scale-110"
                    : "bg-white border-gray-200 text-gray-300 dark:bg-slate-900 dark:border-gray-700"
                }
                ${isNext ? "ring-4 ring-black/5 animate-pulse" : ""}
              `}
                >
                  <span class="material-symbols-outlined text-lg!">
                    {step.icon}
                  </span>
                </div>

                {/* Etiqueta - Derecha en móvil, Abajo en Desktop */}
                <span
                  class={`
                flex-1 md:flex-none text-sm md:text-xs font-medium text-left md:text-center ml-4 md:ml-0 md:mt-4 leading-tight transition-colors duration-500
                ${
                  isCompleted
                    ? "text-black dark:text-white font-bold"
                    : "text-gray-400"
                }
              `}
                >
                  {step.label}
                </span>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style>
  .progress-bar-h {
    width: 0%;
    animation: fillProgressH 1.5s ease-out forwards;
    animation-delay: 0.5s;
  }

  .progress-bar-v {
    height: 0%;
    animation: fillProgressV 1.5s ease-out forwards;
    animation-delay: 0.5s;
  }

  @keyframes fillProgressH {
    from {
      width: 0%;
    }
    to {
      width: var(--target-width);
    }
  }

  @keyframes fillProgressV {
    from {
      height: 0%;
    }
    to {
      height: var(--target-height);
    }
  }

  .material-symbols-outlined {
    font-variation-settings:
      "FILL" 1,
      "wght" 400,
      "GRAD" 0,
      "opsz" 24;
  }
</style>
