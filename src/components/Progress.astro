---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

/**
 * Componente de Progreso Automatizado
 * Calcula el estado basándose en la fecha actual del servidor/cliente.
 */
const now = new Date();

const steps = [
  {
    date: new Date("2026-01-16"),
    label: t("progress.step1_label"),
    icon: "info",
    displayDate: t("progress.step1_date"),
  },
  {
    date: new Date("2026-04-01"),
    label: t("progress.step2_label"),
    icon: "mail",
    displayDate: t("progress.step2_date"),
  },
  {
    date: new Date("2026-08-01"),
    label: t("progress.step3_label"),
    icon: "check_circle",
    displayDate: t("progress.step3_date"),
  },
  {
    date: new Date("2026-09-01"),
    label: t("progress.step4_label"),
    icon: "celebration",
    displayDate: t("progress.step4_date"),
  },
  {
    date: new Date("2026-10-10"),
    label: t("progress.step5_label"),
    icon: "favorite",
    displayDate: t("progress.step5_date"),
  },
];

const activeIndex = steps.findLastIndex((step) => now >= step.date);
const progressPercent =
  activeIndex === -1 ? 0 : (activeIndex / (steps.length - 1)) * 100;
---

<section
  id="countdown"
  class="w-full py-16 md:py-24 px-4 bg-transparent overflow-hidden"
>
  <div class="max-w-4xl mx-auto">
    <h3
      class="text-2xl md:text-3xl font-display font-semibold text-center mb-12 md:mb-20 text-text-main-light dark:text-white"
    >
      {t("progress.agenda_title")}
    </h3>

    <div class="relative px-2 md:px-0">
      <!-- Línea base - Horizontal (Desktop) -->
      <div
        class="hidden md:block absolute top-[43.5%] left-0 right-0 h-1 bg-pearl-grey dark:bg-white/10 rounded-full"
      >
      </div>

      <!-- Línea base - Vertical (Móvil) -->
      <div
        class="md:hidden absolute left-[8.6rem] top-6 bottom-6 w-1 bg-pearl-grey dark:bg-white/10 rounded-full"
      >
      </div>

      <!-- Progreso - Horizontal (Desktop) -->
      <div
        class="progress-bar-h hidden md:block absolute left-0 top-[43.5%] h-1 bg-primary rounded-full transition-all duration-1000 origin-left"
        style={`--target-width: ${progressPercent}%`}
      >
      </div>

      <!-- Progreso - Vertical (Móvil) -->
      <div
        class="progress-bar-v md:hidden absolute left-[7.4rem] top-6 w-1 bg-primary rounded-full transition-all duration-1000 origin-top"
        style={`--target-height: ${progressPercent}%`}
      >
      </div>

      <div
        class="relative flex flex-col md:flex-row justify-between items-stretch md:items-start w-full gap-y-10 md:gap-y-0"
      >
        {
          steps.map((step) => {
            const isCompleted = now >= step.date;

            return (
              <div class="flex flex-row md:flex-col items-center w-full md:flex-1 min-w-0 z-10 group">
                {/* Fecha */}
                <div class="flex flex-col items-end md:items-center w-24 md:w-full mr-4 md:mr-0 md:mb-6 shrink-0">
                  <span
                    class:list={[
                      "text-xs tracking-widest font-medium transition-colors duration-500 text-right md:text-center uppercase",
                      isCompleted
                        ? "text-primary"
                        : "text-gray-400 dark:text-gray-500",
                    ]}
                  >
                    {step.displayDate}
                  </span>
                </div>

                {/* Círculo con Icono */}
                <div
                  class:list={[
                    "relative z-20 size-10 md:size-12 rounded-full flex items-center justify-center border-4 border-solid transition-all duration-700 shrink-0 group-hover:scale-110",
                    isCompleted
                      ? "bg-primary border-white dark:border-background-dark text-white shadow-lg scale-105 md:scale-110"
                      : "bg-white dark:bg-background-dark border-pearl-grey dark:border-white/10 text-gray-300",
                  ]}
                >
                  <span class="material-symbols-outlined text-base md:text-xl!">
                    {step.icon}
                  </span>
                </div>

                {/* Etiqueta */}
                <div class="flex-1 md:w-full ml-5 md:ml-0 md:mt-6">
                  <span
                    class:list={[
                      "block text-xs font-semibold tracking-wide text-left md:text-center leading-tight transition-colors duration-500",
                      isCompleted
                        ? "text-text-main-light dark:text-white"
                        : "text-gray-400",
                    ]}
                  >
                    {step.label}
                  </span>
                </div>
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style>
  .progress-bar-h {
    width: 0%;
    animation: fillProgressH 1.8s cubic-bezier(0.4, 0.45, 0.15, 1) forwards;
    animation-delay: 0.8s;
  }

  .progress-bar-v {
    height: 0%;
    animation: fillProgressV 1.8s cubic-bezier(0.4, 0.45, 0.15, 1) forwards;
    animation-delay: 0.8s;
  }

  @keyframes fillProgressH {
    from {
      width: 0%;
    }
    to {
      width: var(--target-width);
    }
  }

  @keyframes fillProgressV {
    from {
      height: 0%;
    }
    to {
      height: var(--target-height);
    }
  }

  .material-symbols-outlined {
    font-variation-settings:
      "FILL" 1,
      "wght" 400,
      "GRAD" 0,
      "opsz" 24;
  }
</style>
