---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import IntroFlap from "./IntroFlap.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div
  id="intro-gate"
  class="fixed inset-0 z-100 bg-[#b48c3c] flex flex-col items-center justify-center transition-opacity duration-1500 ease-in-out"
>
  <div
    id="envelope-wrapper"
    class="relative group cursor-pointer flex flex-col items-center justify-center w-full h-full overflow-hidden"
    style="perspective: 3500px;"
  >
    <!-- Tap hint -->
    <div
      id="tap-hint"
      class="absolute top-12 md:top-20 z-100 animate-pulse transition-opacity duration-700 group-hover:opacity-80"
    >
      <p
        class="font-body text-white/40 uppercase tracking-[0.3em] md:tracking-[0.6em] text-[10px] md:text-sm font-bold drop-shadow-[0_4px_6px_rgba(0,0,0,0.3)]"
      >
        {t("intro.tapToOpen")}
      </p>
    </div>

    <!-- Hyper-Realistic "Modella" Golden Envelope -->
    <div
      class="relative w-full h-full transition-transform duration-1200 ease-out"
    >
      <!-- Envelope Cavity (Internal Deep Shading) -->
      <div
        class="absolute inset-0 bg-[#a68245] shadow-[inset_0_0_200px_rgba(0,0,0,0.5)]"
      >
        <!-- Ribbed texture -->
        <div
          class="absolute inset-0"
          style="background-image: repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(0,0,0,0.04) 2px, rgba(0,0,0,0.04) 4px);"
        >
        </div>
        <!-- Micro-texture noise layer -->
        <div
          class="absolute inset-0 opacity-[0.08] pointer-events-none mix-blend-multiply bg-[url('https://www.transparenttextures.com/patterns/natural-paper.png')]"
        >
        </div>
      </div>

      <!-- Invitation card inside (Premium Dark) -->
      <div
        id="invitation-card"
        class="absolute inset-x-6 md:inset-x-32 bottom-12 md:bottom-32 h-[80%] bg-background-dark shadow-[0_45px_90px_rgba(0,0,0,0.7),0_15px_30px_rgba(0,0,0,0.4)] rounded-sm z-10 flex flex-col items-center justify-center transition-transform duration-1400 ease-in-out border border-white/10 overflow-hidden"
      >
        <div
          class="font-display text-5xl md:text-9xl text-white drop-shadow-lg"
        >
          M & O
        </div>
        <div class="w-16 md:w-32 h-px bg-white/30 my-10 md:my-16"></div>
        <div
          class="font-body text-sm md:text-xl text-white/70 uppercase tracking-[0.4em] md:tracking-[0.7em]"
        >
          {t("countdown.date")}
        </div>
        <div
          class="font-body text-xs md:text-sm text-white/50 uppercase tracking-[0.2em] md:tracking-[0.4em] mt-8"
        >
          {t("hero.location")}
        </div>
      </div>

      <!-- SIDE FLAPS (Ambient Occlusion & Fiber Realism) -->
      <div class="absolute inset-0 z-20 pointer-events-none">
        <!-- Left Flap -->
        <div
          class="absolute left-0 top-0 bottom-0 w-2/3 bg-[#b48c3c] [clip-path:polygon(0_0,0_100%,100%_50%)] shadow-[-15px_0_45px_rgba(0,0,0,0.3)] border-r border-black/15"
          style="background-image: repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);"
        >
          <!-- Parchment fiber overlay -->
          <div
            class="absolute inset-0 opacity-[0.06] mix-blend-multiply bg-[url('https://www.transparenttextures.com/patterns/handmade-paper.png')]"
          >
          </div>
          <!-- Realistic light falloff (Soft occlusion) -->
          <div
            class="absolute inset-0 bg-linear-to-r from-black/15 via-black/5 to-transparent"
          >
          </div>
          <div
            class="absolute inset-0 bg-linear-to-b from-white/12 via-transparent to-black/12"
          >
          </div>
          <!-- Fold edge highlight (Catching light on paper fibers) -->
          <div
            class="absolute top-0 right-0 bottom-0 w-[1.5px] bg-white/25 blur-[0.3px]"
          >
          </div>
        </div>

        <!-- Right Flap -->
        <div
          class="absolute right-0 top-0 bottom-0 w-2/3 bg-[#b48c3c] [clip-path:polygon(100%_0,100%_100%,0_50%)] shadow-[15px_0_45px_rgba(0,0,0,0.3)] border-l border-black/15"
          style="background-image: repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);"
        >
          <!-- Parchment fiber overlay -->
          <div
            class="absolute inset-0 opacity-[0.06] mix-blend-multiply bg-[url('https://www.transparenttextures.com/patterns/handmade-paper.png')]"
          >
          </div>
          <!-- Realistic light falloff (Soft occlusion) -->
          <div
            class="absolute inset-0 bg-linear-to-l from-black/15 via-black/5 to-transparent"
          >
          </div>
          <div
            class="absolute inset-0 bg-linear-to-b from-white/12 via-transparent to-black/12"
          >
          </div>
          <!-- Fold edge highlight -->
          <div
            class="absolute top-0 left-0 bottom-0 w-[1.5px] bg-white/25 blur-[0.3px]"
          >
          </div>
        </div>
      </div>

      <!-- BOTTOM FLAP (Extreme Thickness & Surface Depth) -->
      <div class="absolute inset-0 z-20 pointer-events-none">
        <div
          class="absolute left-0 right-0 bottom-0 h-3/5 bg-[#b48c3c] [clip-path:polygon(0_100%,100%_100%,50%_0)] shadow-[0_-25px_60px_rgba(0,0,0,0.35)] border-t border-white/10"
          style="background-image: repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);"
        >
          <!-- Fiber overlay -->
          <div
            class="absolute inset-0 opacity-[0.06] mix-blend-multiply bg-[url('https://www.transparenttextures.com/patterns/handmade-paper.png')]"
          >
          </div>
          <!-- Realistic highlight on top edge of fold -->
          <div
            class="absolute top-0 left-0 right-0 h-[2px] bg-white/40 blur-[0.8px]"
          >
          </div>
          <!-- Inner relief shadow -->
          <div
            class="absolute inset-0 bg-linear-to-t from-black/20 via-transparent to-transparent opacity-80"
          >
          </div>
          <!-- Side occlusion shadow simulation (Layered) -->
          <div
            class="absolute inset-0 bg-linear-to-br from-black/15 via-transparent to-transparent opacity-60"
          >
          </div>
        </div>
      </div>

      <IntroFlap />
    </div>

    <!-- Scroll hint -->
    <div
      id="scroll-hint"
      class="absolute bottom-10 z-50 flex flex-col items-center gap-2 animate-float opacity-0 transition-opacity duration-1000 delay-200"
    >
      <span
        class="text-[10px] md:text-xs uppercase tracking-widest text-white/30 font-body font-bold drop-shadow-md"
        >{t("intro.scrollHint")}</span
      >
      <span
        class="material-symbols-outlined text-white/30 text-4xl animate-bounce"
        >keyboard_arrow_down</span
      >
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const gate = document.getElementById("intro-gate");
    const wrapper = document.getElementById("envelope-wrapper");
    const topFlap = document.getElementById("top-flap");
    const card = document.getElementById("invitation-card");
    const seal = document.getElementById("wax-seal");
    const hint = document.getElementById("tap-hint");
    const scrollHint = document.getElementById("scroll-hint");

    if (wrapper) {
      wrapper.addEventListener("click", () => {
        if (hint) hint.style.opacity = "0";
        if (scrollHint) scrollHint.style.opacity = "0";

        if (topFlap) {
          topFlap.style.transition =
            "all 1.7s cubic-bezier(0.45, 0.05, 0.55, 0.95)";
          topFlap.style.transform = "rotateX(180deg)";
          topFlap.style.zIndex = "1";
        }

        if (seal) {
          seal.style.transition =
            "opacity 0.7s ease-out, transform 0.7s ease-out";
          seal.style.opacity = "0";
          seal.style.transform =
            "translate(-50%, -80%) scale(1.1) rotate(5deg)";
        }

        setTimeout(() => {
          if (card) {
            card.style.transform = "translateY(-45%)";
            card.style.zIndex = "25";
          }
        }, 1400);

        setTimeout(() => {
          if (gate) {
            gate.style.opacity = "0";
            gate.style.pointerEvents = "none";
          }
        }, 3800);

        setTimeout(() => {
          gate?.remove();
        }, 6500);
      });
    }
  });
</script>
