---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div
  id="intro-gate"
  class="fixed inset-0 z-[100] bg-secondary-mint flex flex-col items-center justify-center transition-opacity duration-[1500ms] ease-in-out"
>
  <div
    id="envelope-wrapper"
    class="relative group cursor-pointer flex flex-col items-center justify-center"
    style="perspective: 1500px;"
  >
    <!-- Tap hint -->
    <div
      id="tap-hint"
      class="mb-8 md:mb-16 animate-pulse transition-opacity duration-700 group-hover:opacity-80"
    >
      <p
        class="font-body text-primary-dark/60 uppercase tracking-[0.3em] md:tracking-[0.4em] text-[10px] md:text-xs font-medium"
      >
        {t("intro.tapToOpen")}
      </p>
    </div>

    <!-- Envelope container -->
    <div
      class="relative w-[90vw] max-w-[400px] md:max-w-[700px] aspect-[1.5/1] transition-transform duration-700 hover:scale-[1.02]"
    >
      <!-- Shadow -->
      <div
        class="absolute inset-0 bg-primary-dark/20 shadow-2xl rounded-sm transform translate-y-2 translate-x-1 opacity-40 blur-sm"
      >
      </div>

      <!-- Envelope body -->
      <div
        class="absolute inset-0 bg-linear-to-b from-secondary-mint to-primary-light/40 rounded-sm shadow-xl border border-white/40"
      >
      </div>

      <!-- Invitation card inside -->
      <div
        id="invitation-card"
        class="absolute left-4 right-4 md:left-6 md:right-6 bottom-2 md:bottom-3 h-[92%] bg-white shadow-inner rounded-sm z-10 flex flex-col items-center justify-start pt-10 md:pt-16 transition-transform duration-1200 ease-in-out border border-gray-50"
      >
        <div
          class="font-display text-5xl md:text-7xl text-primary drop-shadow-sm"
        >
          M & O
        </div>
        <div class="w-12 md:w-16 h-px bg-primary/30 my-6 md:my-8"></div>
        <div
          class="font-body text-xs md:text-sm text-gray-400 uppercase tracking-[0.2em] md:tracking-[0.25em]"
        >
          {t("countdown.date")}
        </div>
        <div
          class="font-body text-[10px] md:text-xs text-gray-300 uppercase tracking-[0.15em] md:tracking-[0.2em] mt-2"
        >
          {t("hero.location")}
        </div>
      </div>

      <!-- Side flaps -->
      <div class="absolute inset-0 z-20 pointer-events-none">
        <div
          class="absolute left-0 top-0 bottom-0 w-2/3 bg-primary-light/60 [clip-path:polygon(0_0,0_100%,100%_50%)] shadow-sm"
        >
        </div>
        <div
          class="absolute right-0 top-0 bottom-0 w-2/3 bg-primary-light/60 [clip-path:polygon(100%_0,100%_100%,0_50%)] shadow-sm"
        >
        </div>
      </div>

      <!-- Bottom flap -->
      <div class="absolute inset-0 z-20 pointer-events-none">
        <div
          class="absolute left-0 right-0 bottom-0 h-2/3 bg-primary-light/70 [clip-path:polygon(0_100%,100%_100%,50%_0)] shadow-lg"
        >
        </div>
      </div>

      <!-- Top flap with seal -->
      <div
        id="top-flap"
        class="absolute inset-0 z-30 origin-top transition-all duration-1500 ease-in-out"
        style="transform-style: preserve-3d;"
      >
        <div
          id="wax-seal"
          class="absolute top-[55%] left-1/2 -translate-x-1/2 -translate-y-1/2 size-24 md:size-36 wax-seal-shape bg-gradient-to-br from-primary-dark via-primary to-primary-dark flex items-center justify-center z-40 cursor-pointer transition-all duration-500 group-hover:scale-105"
        >
          <div
            class="absolute inset-1 wax-rim bg-gradient-to-tl from-primary-dark to-primary-light opacity-50"
          >
          </div>
          <div
            class="absolute inset-3 md:inset-4 rounded-full shadow-[inset_2px_2px_4px_rgba(0,0,0,0.3),inset_-1px_-1px_2px_rgba(255,255,255,0.4)] bg-primary flex items-center justify-center border border-primary-dark/20"
          >
            <div
              class="absolute inset-2 rounded-full border border-primary-dark/40 shadow-[0_1px_1px_rgba(255,255,255,0.3)]"
            >
            </div>
            <span
              class="font-display text-3xl md:text-5xl font-bold pt-1 md:pt-2 opacity-95 wax-engraved-text relative z-10 drop-shadow-[0_1px_1px_rgba(255,255,255,0.5)]"
              >MO</span
            >
            <div
              class="absolute inset-0 rounded-full bg-gradient-to-r from-transparent via-white/20 to-transparent skew-x-12 animate-shimmer pointer-events-none"
            >
            </div>
          </div>
        </div>
        <div
          class="absolute top-0 left-0 right-0 h-full bg-linear-to-b from-secondary-mint to-primary-light [clip-path:polygon(0_0,100%_0,50%_55%)] drop-shadow-md"
        >
          <!-- Wax seal -->
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div
      id="scroll-hint"
      class="absolute -bottom-16 md:-bottom-24 flex flex-col items-center gap-2 md:gap-3 animate-float opacity-0 transition-opacity duration-1000 delay-200"
    >
      <span
        class="text-[10px] md:text-xs uppercase tracking-widest text-gray-400 font-body"
        >{t("intro.scrollHint")}</span
      >
      <span
        class="material-symbols-outlined text-gray-400 text-2xl md:text-3xl animate-bounce"
        >keyboard_arrow_down</span
      >
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const gate = document.getElementById("intro-gate");
    const wrapper = document.getElementById("envelope-wrapper");
    const topFlap = document.getElementById("top-flap");
    const card = document.getElementById("invitation-card");
    const seal = document.getElementById("wax-seal");
    const hint = document.getElementById("tap-hint");
    const scrollHint = document.getElementById("scroll-hint");

    if (wrapper) {
      wrapper.addEventListener("click", () => {
        // Hide hints
        if (hint) hint.style.opacity = "0";
        if (scrollHint) scrollHint.style.opacity = "0";

        // Open flap
        if (topFlap) {
          topFlap.style.transition = "all 1.2s ease-in-out";
          topFlap.style.transform = "rotateX(180deg)";
          topFlap.style.zIndex = "1";
        }

        // Hide seal
        if (seal) {
          seal.style.transition = "opacity 0.4s ease-out";
          seal.style.opacity = "0";
        }

        // Slide card up
        setTimeout(() => {
          if (card) {
            card.style.transform = "translateY(-100px)";
            card.style.zIndex = "25";
          }
        }, 1000);

        // Fade out gate
        setTimeout(() => {
          if (gate) {
            gate.style.opacity = "0";
            gate.style.pointerEvents = "none";
          }
        }, 2800);

        // Remove gate
        setTimeout(() => {
          gate?.remove();
        }, 4500);
      });
    }
  });
</script>
