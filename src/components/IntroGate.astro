---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import IntroFlap from "./IntroFlap.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div
  id="intro-gate"
  class="fixed inset-0 z-100 bg-secondary-mint flex flex-col items-center justify-center transition-opacity duration-1500 ease-in-out"
>
  <div
    id="envelope-wrapper"
    class="relative group cursor-pointer flex flex-col items-center justify-center w-full h-full"
    style="perspective: 1500px;"
  >
    <!-- Tap hint -->
    <div
      id="tap-hint"
      class="absolute top-10 md:top-20 z-50 animate-pulse transition-opacity duration-700 group-hover:opacity-80"
    >
      <p
        class="font-body text-primary-dark/60 uppercase tracking-[0.3em] md:tracking-[0.4em] text-[10px] md:text-xs font-medium"
      >
        {t("intro.tapToOpen")}
      </p>
    </div>

    <!-- Envelope container (Fullscreen) -->
    <div
      class="relative w-full h-full transition-transform duration-700 overflow-hidden"
    >
      <!-- Shadow -->
      <div
        class="absolute inset-0 bg-primary-dark/10 opacity-40 blur-sm pointer-events-none"
      >
      </div>

      <!-- Envelope body -->
      <div
        class="absolute inset-0 bg-linear-to-b from-secondary-mint to-primary-light/40 shadow-xl"
      >
      </div>

      <!-- Invitation card inside (Forced Dark Mode) -->
      <div
        id="invitation-card"
        class="absolute inset-x-4 md:inset-x-10 bottom-4 md:bottom-10 h-[85%] bg-background-dark shadow-2xl rounded-sm z-10 flex flex-col items-center justify-center transition-transform duration-1200 ease-in-out border border-white/5"
      >
        <div
          class="font-display text-5xl md:text-8xl text-white drop-shadow-sm"
        >
          M & O
        </div>
        <div class="w-12 md:w-20 h-px bg-white/20 my-8 md:my-12"></div>
        <div
          class="font-body text-sm md:text-lg text-white/60 uppercase tracking-[0.2em] md:tracking-[0.3em]"
        >
          {t("countdown.date")}
        </div>
        <div
          class="font-body text-xs md:text-sm text-white/40 uppercase tracking-[0.15em] md:tracking-[0.2em] mt-4"
        >
          {t("hero.location")}
        </div>
      </div>

      <!-- Side flaps -->
      <div class="absolute inset-0 z-20 pointer-events-none">
        <div
          class="absolute left-0 top-0 bottom-0 w-2/3 bg-primary-light/60 [clip-path:polygon(0_0,0_100%,100%_50%)] shadow-sm"
        >
        </div>
        <div
          class="absolute right-0 top-0 bottom-0 w-2/3 bg-primary-light/60 [clip-path:polygon(100%_0,100%_100%,0_50%)] shadow-sm"
        >
        </div>
      </div>

      <!-- Bottom flap -->
      <div class="absolute inset-0 z-20 pointer-events-none">
        <div
          class="absolute left-0 right-0 bottom-0 h-2/3 bg-primary-light/70 [clip-path:polygon(0_100%,100%_100%,50%_0)] shadow-lg"
        >
        </div>
      </div>

      <IntroFlap />
    </div>

    <!-- Scroll hint -->
    <div
      id="scroll-hint"
      class="absolute bottom-10 z-50 flex flex-col items-center gap-2 md:gap-3 animate-float opacity-0 transition-opacity duration-1000 delay-200"
    >
      <span
        class="text-[10px] md:text-xs uppercase tracking-widest text-gray-400 font-body"
        >{t("intro.scrollHint")}</span
      >
      <span
        class="material-symbols-outlined text-gray-400 text-2xl md:text-3xl animate-bounce"
        >keyboard_arrow_down</span
      >
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const gate = document.getElementById("intro-gate");
    const wrapper = document.getElementById("envelope-wrapper");
    const topFlap = document.getElementById("top-flap");
    const card = document.getElementById("invitation-card");
    const seal = document.getElementById("wax-seal");
    const hint = document.getElementById("tap-hint");
    const scrollHint = document.getElementById("scroll-hint");

    if (wrapper) {
      wrapper.addEventListener("click", () => {
        // Hide hints
        if (hint) hint.style.opacity = "0";
        if (scrollHint) scrollHint.style.opacity = "0";

        // Open flap
        if (topFlap) {
          topFlap.style.transition = "all 1.2s ease-in-out";
          topFlap.style.transform = "rotateX(180deg)";
          topFlap.style.zIndex = "1";
        }

        // Hide seal
        if (seal) {
          seal.style.transition = "opacity 0.4s ease-out";
          seal.style.opacity = "0";
        }

        // Slide card up
        setTimeout(() => {
          if (card) {
            // Full screen vertical slide
            card.style.transform = "translateY(-40%)";
            card.style.zIndex = "25";
          }
        }, 1000);

        // Fade out gate
        setTimeout(() => {
          if (gate) {
            gate.style.opacity = "0";
            gate.style.pointerEvents = "none";
          }
        }, 2800);

        // Remove gate from DOM
        setTimeout(() => {
          gate?.remove();
        }, 4500);
      });
    }
  });
</script>
