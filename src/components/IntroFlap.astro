---

<div
  id="top-flap"
  class="absolute inset-x-0 top-0 h-full z-30 origin-top transition-all duration-1500 ease-in-out"
  style="transform-style: preserve-3d;"
>
  <!-- Hi-Fi Organic Wax Seal (Profound Volume) -->
  <div
    id="wax-seal"
    class="absolute top-[50%] left-1/2 -translate-x-1/2 -translate-y-1/2 size-32 md:size-48 z-40 cursor-pointer transition-all duration-800 group-hover:scale-105"
  >
    <!-- Organic Wax Base -->
    <div
      class="absolute inset-0 bg-[#7c883f] rounded-[47%_53%_44%_56%/56%_47%_53%_44%] shadow-[0_20px_45px_rgba(0,0,0,0.6),inset_0_-10px_20px_rgba(0,0,0,0.5),inset_0_6px_20px_rgba(255,255,255,0.3)] border-2 border-black/25 flex items-center justify-center animate-subtle-drift"
    >
      <!-- Pressed Cavity -->
      <div
        class="absolute inset-5 md:inset-8 rounded-full bg-[#7c883f] shadow-[inset_0_8px_20px_rgba(0,0,0,0.7),0_3px_6px_rgba(255,255,255,0.2)] border border-black/25 flex items-center justify-center overflow-hidden"
      >
        <!-- Textures -->
        <div
          class="absolute inset-0 bg-linear-to-tr from-black/30 via-transparent to-white/15 opacity-40"
        >
        </div>
        <div
          class="absolute size-[85%] rounded-full border border-black/20 opacity-30"
        >
        </div>
        <div
          class="absolute size-[40%] rounded-full bg-black/10 blur-sm opacity-20"
        >
        </div>
      </div>

      <!-- Realistic Highlights -->
      <div
        class="absolute top-[12%] left-[12%] size-[35%] bg-white/20 blur-xl rounded-full pointer-events-none"
      >
      </div>
      <div
        class="absolute top-[8%] left-[28%] size-[20%] bg-white/25 blur-md rounded-full pointer-events-none"
      >
      </div>
    </div>
  </div>

  <!-- Fullscreen Top Flap (Extreme Paper Relief) -->
  <div
    class="absolute top-0 left-0 right-0 h-full bg-[#ecc18d] [clip-path:polygon(0_0,100%_0,50%_50%)] shadow-[0_25px_50px_rgba(0,0,0,0.45)]"
  >
    <!-- Surface lighting -->
    <div
      class="absolute inset-0 bg-linear-to-b from-white/20 via-transparent to-black/25 opacity-90 pointer-events-none"
    >
    </div>

    <!-- Edge highlight (Top light) -->
    <div
      class="absolute bottom-0 left-0 right-0 h-[4px] bg-white/40 blur-[1px]"
    >
    </div>

    <!-- Deep contact shadow -->
    <div
      class="absolute bottom-0 left-0 right-0 h-full bg-linear-to-t from-black/30 via-transparent to-transparent opacity-50"
    >
    </div>

    <!-- Realistic micro-texture simulation -->
    <div
      class="absolute inset-0 opacity-[0.05] mix-blend-overlay bg-[url('https://www.transparenttextures.com/patterns/natural-paper.png')]"
    >
    </div>
  </div>
</div>

<style>
  @keyframes subtle-drift {
    0%,
    100% {
      transform: scale(1) rotate(0deg);
    }
    33% {
      transform: scale(1.04) rotate(1.5deg);
    }
    66% {
      transform: scale(0.97) rotate(-1.5deg);
    }
  }
  .animate-subtle-drift {
    animation: subtle-drift 6s ease-in-out infinite;
  }
</style>
