---

---

<div
  id="top-flap"
  class="absolute inset-0 z-30 origin-top transition-all duration-1500 ease-in-out"
  style="transform-style: preserve-3d;"
>
  <!-- Hyper-Realistic Global Golden Heart Wax Seal -->
  <div
    id="wax-seal"
    class="absolute top-[50%] left-1/2 -translate-x-1/2 -translate-y-1/2 size-20 md:size-30 z-40 cursor-pointer transition-all duration-800 group-hover:scale-110"
  >
    <!-- Organic Wax Base Shape (Metallic Gold with High Volume) -->
    <div
      class="absolute inset-0 bg-[#c5a059] rounded-full shadow-[0_15px_35px_rgba(0,0,0,0.5),inset_0_-5px_10px_rgba(0,0,0,0.4),inset_0_4px_10px_rgba(255,255,255,0.4)] border border-[#a68245]/50 flex items-center justify-center overflow-hidden animate-subtle-breathing"
    >
      <!-- Deep Pressed Center with Heart Icon -->
      <div
        class="absolute inset-1.5 md:inset-2.5 rounded-full bg-[#c5a059] shadow-[inset_0_8px_16px_rgba(0,0,0,0.7),0_2px_4px_rgba(255,255,255,0.2)] border border-[#a68245]/30 flex items-center justify-center"
      >
        <!-- Heart Minimalist Icon (Etched look) -->
        <svg
          viewBox="0 0 24 24"
          class="size-8 md:size-12 text-[#7d6023] opacity-90 drop-shadow-[0_1px_0_rgba(255,255,255,0.2)]"
          fill="currentColor"
        >
          <path
            d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
          ></path>
        </svg>
      </div>

      <!-- Realistic Multi-Point Surface Speculars -->
      <div
        class="absolute top-[12%] left-[12%] size-[35%] bg-white/15 blur-lg rounded-full pointer-events-none"
      >
      </div>
      <div
        class="absolute top-[5%] left-[30%] size-[15%] bg-white/20 blur-sm rounded-full pointer-events-none"
      >
      </div>
      <div
        class="absolute bottom-[20%] right-[20%] size-[20%] bg-black/10 blur-md rounded-full pointer-events-none"
      >
      </div>
    </div>
  </div>

  <!-- Fullscreen Top Flap (Modella Texture - Hyper Relief) -->
  <div
    class="absolute top-0 left-0 right-0 h-full bg-[#b48c3c] [clip-path:polygon(0_0,100%_0,50%_50%)] shadow-[0_25px_55px_rgba(0,0,0,0.45)]"
    style="background-image: repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);"
  >
    <!-- Fiber overlay for tactile realism -->
    <div
      class="absolute inset-0 opacity-[0.06] mix-blend-multiply bg-[url('https://www.transparenttextures.com/patterns/natural-paper.png')]"
    >
    </div>

    <!-- Complex paper surface depth and lighting -->
    <div
      class="absolute inset-0 bg-linear-to-b from-white/18 via-transparent to-black/28 opacity-90 pointer-events-none"
    >
    </div>

    <!-- Triple Edge Relief (Realistic paper thickness highlight) -->
    <div
      class="absolute bottom-0 left-0 right-0 h-[4px] bg-white/35 blur-[0.6px]"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 right-0 h-[8px] bg-white/12 blur-[2.5px]"
    >
    </div>

    <!-- Deep Contact Shadow on hidden flaps -->
    <div
      class="absolute bottom-0 left-0 right-0 h-full bg-linear-to-t from-black/30 via-transparent to-transparent opacity-60"
    >
    </div>
  </div>
</div>

<style>
  @keyframes subtle-breathing {
    0%,
    100% {
      transform: scale(1) rotate(0deg);
    }
    50% {
      transform: scale(1.02) rotate(0.5deg);
    }
  }
  .animate-subtle-breathing {
    animation: subtle-breathing 8s ease-in-out infinite;
  }
</style>
