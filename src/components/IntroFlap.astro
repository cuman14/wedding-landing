<div
  id="top-flap"
  class="absolute inset-0 z-30 origin-top transition-all duration-1500 ease-in-out"
  style="transform-style: preserve-3d;"
>
  <div
    id="wax-seal"
    class="absolute top-[45%] left-1/2 -translate-x-1/2 -translate-y-1/2 size-24 md:size-32 wax-seal-shape bg-linear-to-br from-primary-dark via-primary to-primary-dark flex items-center justify-center z-40 cursor-pointer transition-all duration-500 group-hover:scale-105"
  >
    <div
      class="absolute inset-1 wax-rim bg-linear-to-tl from-primary-dark to-primary-light opacity-50"
    >
    </div>
    <div
      class="absolute inset-3 md:inset-4 rounded-full shadow-[inset_2px_2px_4px_rgba(0,0,0,0.3),inset_-1px_-1px_2px_rgba(255,255,255,0.4)] bg-primary flex items-center justify-center border border-primary-dark/20"
    >
      <div
        class="absolute inset-2 rounded-full border border-primary-dark/40 shadow-[0_1px_1px_rgba(255,255,255,0.3)]"
      >
      </div>
      <span
        class="font-display text-3xl md:text-5xl font-bold pt-1 md:pt-2 opacity-95 wax-engraved-text relative z-10 drop-shadow-[0_1px_1px_rgba(255,255,255,0.5)]"
      ></span>
      <div
        class="absolute inset-0 rounded-full bg-linear-to-r from-transparent via-white/20 to-transparent skew-x-12 animate-shimmer pointer-events-none"
      >
      </div>
    </div>
  </div>
  <div
    class="absolute top-0 left-0 right-0 h-full bg-linear-to-b from-secondary-mint to-primary-light [clip-path:polygon(0_0,100%_0,50%_55%)] drop-shadow-md"
  >
    <!-- Wax seal -->
  </div>
</div>
