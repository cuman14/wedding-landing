---

<div
  id="top-flap"
  class="absolute inset-0 z-30 origin-top transition-all duration-1500 ease-in-out"
  style="transform-style: preserve-3d;"
>
  <!-- Minimalist Golden Heart Wax Seal -->
  <div
    id="wax-seal"
    class="absolute top-[50%] left-1/2 -translate-x-1/2 -translate-y-1/2 size-20 md:size-30 z-40 cursor-pointer transition-all duration-500 group-hover:scale-105"
  >
    <!-- Wax Base Shape (Metallic Gold) -->
    <div
      class="absolute inset-0 bg-[#c5a059] rounded-full shadow-[0_8px_20px_rgba(0,0,0,0.4),inset_0_-2px_4px_rgba(0,0,0,0.2),inset_0_2px_4px_rgba(255,255,255,0.2)] border border-[#a68245]/30 flex items-center justify-center overflow-hidden"
    >
      <!-- Pressed Center with Heart Icon -->
      <div
        class="absolute inset-1.5 md:inset-2.5 rounded-full bg-[#c5a059] shadow-[inset_0_4px_8px_rgba(0,0,0,0.4)] border border-[#a68245]/20 flex items-center justify-center"
      >
        <!-- Heart/V Minimalist Icon -->
        <svg
          viewBox="0 0 24 24"
          class="size-8 md:size-12 text-[#8a6a2a] opacity-70"
          fill="currentColor"
        >
          <path
            d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
          ></path>
        </svg>
      </div>

      <!-- Subtle Shine -->
      <div
        class="absolute top-1 left-2 size-full bg-white/5 blur-lg rounded-full pointer-events-none"
      >
      </div>
    </div>
  </div>

  <!-- Fullscreen Top Flap (Modella Texture) -->
  <div
    class="absolute top-0 left-0 right-0 h-full bg-[#b48c3c] [clip-path:polygon(0_0,100%_0,50%_50%)] shadow-[0_15px_30px_rgba(0,0,0,0.25)] border-b border-white/5"
    style="background-image: repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(0,0,0,0.02) 2px, rgba(0,0,0,0.02) 4px);"
  >
    <!-- Paper relief lighting -->
    <div
      class="absolute inset-0 bg-linear-to-b from-white/10 via-transparent to-black/15 pointer-events-none"
    >
    </div>
    <!-- Edge highlight -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-white/20 blur-[0.5px]">
    </div>
  </div>
</div>
