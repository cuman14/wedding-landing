---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="video-section"
  class="py-12 md:py-20 bg-secondary-mint/30 dark:bg-background-dark/50 border-b border-pearl-grey dark:border-white/5"
>
  <div class="max-w-6xl mx-auto px-4 md:px-10 flex flex-col items-center">
    <!-- Header -->
    <div class="text-center mb-8 md:mb-12 max-w-2xl">
      <span
        class="text-primary font-body font-medium uppercase tracking-widest text-xs"
        >{t("video.subtitle")}</span
      >
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-display text-text-main-light dark:text-text-main-dark mt-2 mb-4"
      >
        {t("video.title")}
      </h2>
      <p
        class="text-gray-500 dark:text-gray-400 font-light text-sm md:text-base leading-relaxed"
      >
        {t("video.description")}
      </p>
    </div>

    <!-- Video card -->
    <div
      id="video-container"
      class="relative w-full aspect-video rounded-xl md:rounded-2xl overflow-hidden shadow-2xl group bg-black"
    >
      <!-- Video Element with Native Controls Enabled -->
      <video
        id="main-video"
        class="absolute inset-0 w-full h-full object-cover opacity-80 transition-opacity duration-500"
        preload="metadata"
        poster="/poster-finca.webp"
        loop
        playsinline
        controls
        aria-label={t("video.venue")}
      >
        <source src="/video-finca-4-compressed.mp4" type="video/mp4" />
      </video>

      <!-- Custom Play overlay (Initial state) -->
      <div
        id="video-overlay"
        class="absolute inset-0 bg-black/40 flex items-center justify-center transition-opacity duration-500 z-10 cursor-pointer"
      >
        <div
          class="size-16 md:size-24 lg:size-28 rounded-full bg-white/20 backdrop-blur-md border border-white/40 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 shadow-[0_0_40px_rgba(0,0,0,0.4)]"
        >
          <span
            id="play-icon"
            class="material-symbols-outlined text-white text-4xl md:text-6xl ml-1 md:ml-2"
            >play_arrow</span
          >
        </div>

        <!-- Fullscreen hint -->
        <div
          class="absolute bottom-6 right-6 text-white/60 flex items-center gap-2"
        >
          <span
            class="text-[10px] md:text-xs uppercase tracking-widest font-body"
            >{t("video.fullscreen") || "Pantalla Completa"}</span
          >
          <span class="material-symbols-outlined text-xl">fullscreen</span>
        </div>
      </div>

      <!-- Caption bar (Only visible when overlay is present or video is paused) -->
      <div
        id="video-caption"
        class="absolute bottom-0 left-0 right-0 p-4 md:p-8 bg-linear-to-t from-black/90 to-transparent pointer-events-none z-5 transition-opacity duration-500"
      >
        <p class="text-white font-body font-medium text-lg md:text-2xl">
          {t("video.venue")}
        </p>
        <p class="text-white/70 text-xs md:text-base font-light">
          {t("video.venueDesc")}
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const container = document.getElementById("video-container");
  const video = document.getElementById("main-video") as HTMLVideoElement;
  const overlay = document.getElementById("video-overlay");
  const caption = document.getElementById("video-caption");

  if (video && overlay && caption) {
    // Start video and hide overlay
    overlay.addEventListener("click", () => {
      video.play();
      overlay.style.opacity = "0";
      caption.style.opacity = "0";
      setTimeout(() => {
        overlay.style.pointerEvents = "none";
      }, 500);
    });

    // Handle video events to show/hide UI
    video.addEventListener("play", () => {
      overlay.style.opacity = "0";
      caption.style.opacity = "0";
      overlay.style.pointerEvents = "none";
    });

    video.addEventListener("pause", () => {
      overlay.style.opacity = "1";
      caption.style.opacity = "1";
      overlay.style.pointerEvents = "auto";
    });

    // Optional: Fullscreen trigger via double click if desired
    container?.addEventListener("dblclick", () => {
      if (video.requestFullscreen) {
        video.requestFullscreen();
      }
    });
  }
</script>
