---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="video-section"
  class="py-12 md:py-20 bg-secondary-mint/30 dark:bg-background-dark/50 border-b border-pearl-grey dark:border-white/5"
>
  <div class="max-w-6xl mx-auto px-4 md:px-10 flex flex-col items-center">
    <!-- Header -->
    <div class="text-center mb-8 md:mb-12 max-w-2xl">
      <span
        class="text-primary font-body font-medium uppercase tracking-widest text-xs"
        >{t("video.subtitle")}</span
      >
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-display text-text-main-light dark:text-text-main-dark mt-2 mb-4"
      >
        {t("video.title")}
      </h2>
      <p
        class="text-gray-500 dark:text-gray-400 font-light text-sm md:text-base leading-relaxed"
      >
        {t("video.description")}
      </p>
    </div>

    <!-- Video card -->
    <div
      id="video-container"
      class="relative w-full aspect-video rounded-xl md:rounded-2xl overflow-hidden shadow-2xl group cursor-pointer bg-black"
    >
      <video
        id="main-video"
        class="absolute inset-0 w-full h-full object-cover opacity-70 group-hover:opacity-60 transition-opacity duration-500 transform group-hover:scale-105"
        preload="metadata"
        poster="/poster-finca.webp"
        muted
        loop
        playsinline
        aria-label={t("video.venue")}
      >
        <source src="/video-finca-4-compressed.mp4" type="video/mp4" />
      </video>

      <!-- Play/Pause overlay -->
      <div
        id="video-overlay"
        class="absolute inset-0 bg-black/20 flex items-center justify-center transition-opacity duration-300"
      >
        <div
          class="size-16 md:size-20 lg:size-24 rounded-full bg-white/20 backdrop-blur-sm border border-white/40 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 shadow-[0_0_30px_rgba(0,0,0,0.3)]"
        >
          <span
            id="play-icon"
            class="material-symbols-outlined text-white text-4xl md:text-5xl ml-1 md:ml-2"
            >play_arrow</span
          >
        </div>
      </div>

      <!-- Caption bar -->
      <div
        class="absolute bottom-0 left-0 right-0 p-4 md:p-6 bg-linear-to-t from-black/80 to-transparent pointer-events-none"
      >
        <p class="text-white font-body font-medium text-base md:text-lg">
          {t("video.venue")}
        </p>
        <p class="text-white/70 text-xs md:text-sm font-light">
          {t("video.venueDesc")}
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const container = document.getElementById("video-container");
  const video = document.getElementById("main-video") as HTMLVideoElement;
  const overlay = document.getElementById("video-overlay");
  const icon = document.getElementById("play-icon");

  if (container && video && overlay && icon) {
    container.addEventListener("click", () => {
      if (video.paused) {
        video.play();
        overlay.style.opacity = "0";
        setTimeout(() => {
          overlay.classList.add("hidden");
        }, 300);
      } else {
        video.pause();
        overlay.classList.remove("hidden");
        setTimeout(() => {
          overlay.style.opacity = "1";
        }, 10);
      }
    });

    // Show overlay when video ends (if not looping) or if needed
    video.addEventListener("pause", () => {
      overlay.classList.remove("hidden");
      overlay.style.opacity = "1";
    });
  }
</script>
